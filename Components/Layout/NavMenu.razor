@using AcademicWebPortal.Interfaces
@using AcademicWebPortal.Shared
@inherits NavMenuBase

<style>
    .sidebar-container {
        background: #111827; 
        display: flex;
        flex-direction: column;
        height: 100vh;
        padding: 1.25rem;
    }
    .brand-wrapper {
        padding: 0.5rem 0.75rem 1.5rem 0.75rem;
    }
    .nav-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05rem;
        color: #6b7280;
        font-weight: 700;
        margin: 1.5rem 0.75rem 0.5rem 0.75rem;
    }
    .nav-link {
        color: #9ca3af !important;
        border-radius: 10px !important;
        padding: 0.6rem 1rem !important;
        margin-bottom: 0.25rem;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        font-weight: 500;
    }
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.05) !important;
            color: #ffffff !important;
        }

        .nav-link.active {
            background: #3b82f6 !important;
            color: #ffffff !important;
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
        }
        .nav-link i {
            font-size: 1.1rem;
        }
    .user-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 1rem;
        margin-top: auto;
    }
    .avatar-circle {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
    .logout-btn {
        color: #f87171;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: color 0.2s;
        background: none;
        border: none;
        padding: 0;
        margin-top: 0.5rem;
    }

        .logout-btn:hover {
            color: #ef4444;
        }
</style>

<div class="sidebar-container text-white">
    <div class="brand-wrapper">
        <a href="/dashboard" class="d-flex align-items-center text-white text-decoration-none">
            <div class="me-2 d-flex align-items-center justify-content-center bg-primary rounded-3" style="width: 35px; height: 35px;">
                <i class="bi bi-mortarboard-fill fs-5"></i>
            </div>
            <span class="fs-4 fw-bold tracking-tight">EduConnect</span>
        </a>
    </div>
    <ul class="nav nav-pills flex-column">
        <li class="nav-label">Main</li>

        <li class="nav-item">
            <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">
                <i class="bi bi-grid-1x2-fill me-3"></i> Dashboard
            </NavLink>
        </li>
        @if (AuthStateService.IsLoggedIn)
        {
            <li class="nav-item">
                <NavLink class="nav-link d-flex justify-content-between align-items-center" href="/notifications">
                    <div>
                        <i class="bi bi-bell-fill me-3"></i> Notifications
                    </div>
                    @{
                        int unread = NotificationService.GetUnreadCount(AuthStateService.CurrentUser?.Id ?? 0);
                        if (unread > 0)
                        {
                            <span class="badge rounded-pill bg-danger border border-2 border-dark">@unread</span>
                        }
                    }
                </NavLink>
            </li>
            <li class="nav-label">Management</li>
            var role = AuthStateService.CurrentUser?.GetRole();
            @if (role == "Admin")
            {
                <li><NavLink class="nav-link" href="/admin/students"><i class="bi bi-people-fill me-3"></i> Students</NavLink></li>
                <li><NavLink class="nav-link" href="/admin/courses"><i class="bi bi-journal-bookmark-fill me-3"></i> Courses</NavLink></li>
                <li><NavLink class="nav-link" href="/admin/notifications"><i class="bi bi-megaphone-fill me-3"></i> Send Broadcast</NavLink></li>
            }
            else if (role == "Faculty")
            {
                <li><NavLink class="nav-link" href="/faculty/grades"><i class="bi bi-check2-square me-3"></i> Grading</NavLink></li>
                <li><NavLink class="nav-link" href="/faculty/courses"><i class="bi bi-calendar3 me-3"></i> Course Load</NavLink></li>
            }
            else if (role == "Student")
            {
                <li><NavLink class="nav-link" href="/student/enroll"><i class="bi bi-plus-circle-fill me-3"></i> Enrollment</NavLink></li>
                <li><NavLink class="nav-link" href="/student/grades"><i class="bi bi-file-earmark-text-fill me-3"></i> My Grades</NavLink></li>
            }
        }
    </ul>
    @if (AuthStateService.IsLoggedIn)
    {
        <div class="user-card">
            <div class="d-flex align-items-center">
                <div class="avatar-circle me-3">
                    @AuthStateService.CurrentUser?.FullName?[0]
                </div>
                <div class="overflow-hidden">
                    <div class="text-truncate small fw-bold text-white">@AuthStateService.CurrentUser?.FullName</div>
                    <div class="text-truncate text-muted" style="font-size: 0.75rem;">@AuthStateService.CurrentUser?.GetRole()</div>
                </div>
            </div>
            <hr class="my-2" style="opacity: 0.1;">
            <button class="logout-btn w-100 text-start" @onclick="HandleLogout">
                <i class="bi bi-box-arrow-right me-2"></i> Logout
            </button>
        </div>
    }
</div>