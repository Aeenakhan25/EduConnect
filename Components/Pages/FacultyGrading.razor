@page "/faculty/grades"
@using AcademicWebPortal.Models
@using AcademicWebPortal.Interfaces

<div class="container-fluid">
    <h2 class="mb-4">Grading System</h2>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <label class="form-label fw-bold">Select Course to Grade</label>
            <select class="form-select form-select-lg" @bind="SelectedCourseId">
                <option value="0">-- Choose a Course --</option>
                @foreach (var course in Courses)
                {
                    <option value="@course.Id">@course.CourseCode - @course.Title</option>
                }
            </select>
        </div>
    </div>

    @if (SelectedCourseId > 0)
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Enrolled Students</h5>
                <span class="badge bg-primary">@EnrolledStudents.Count Students</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student ID</th>
                                <th>Name</th>
                                <th style="width: 200px;">Marks (0-100)</th>
                                <th>Grade</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in EnrolledStudents)
                            {
                                var grade = GetTempGrade(student.Id);
                                <tr>
                                    <td><strong>@student.StudentId</strong></td>
                                    <td>@student.FullName</td>
                                    <td>
                                        <input type="number" class="form-control" 
                                               @bind="grade.Score" 
                                               @bind:event="oninput"
                                               min="0" max="100" />
                                    </td>
                                    <td>
                                        @{
                                            var (letter, points) = GradeRecord.CalculateGrade(grade.Score);
                                            <span class="badge @GetGradeColor(letter)">@letter (@points.ToString("F1"))</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-primary btn-sm" @onclick="() => SubmitGrade(student.Id)">
                                            Submit
                                        </button>
                                    </td>
                                </tr>
                            }
                            @if (!EnrolledStudents.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">No students are currently enrolled in this course.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
