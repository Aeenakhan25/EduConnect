@page "/"
@page "/dashboard"
@using AcademicWebPortal.Interfaces
@using AcademicWebPortal.Models

<style>
    .welcome-banner {
        background: white;
        border-radius: 24px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        padding: 3rem !important;
    }
    .stat-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #edf2f7;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        padding: 1.5rem;
    }
    .stat-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.07);
    }
    .icon-circle {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
    }
    .btn-action {
        border-radius: 12px;
        padding: 8px 20px;
        font-weight: 600;
        margin-top: 1rem;
    }
</style>

<div class="container-fluid py-4">
    <div class="welcome-banner mb-5">
        <div class="row align-items-center">
            <div class="col-md-9">
                <h1 class="display-5 fw-bold text-dark mb-3">Welcome back, @(AuthStateService.CurrentUser?.FullName ?? "Guest")!</h1>
                <p class="text-secondary fs-4 mb-4">EduConnect Academic Portal is your central hub for course management, grading, and student performance tracking.</p>
                <div class="d-flex align-items-center">
                    <span class="text-uppercase small fw-bold text-muted me-3">Current Access Level:</span>
                    <span class="badge bg-primary rounded-pill px-3 py-2">@AuthStateService.CurrentUser?.GetRole()</span>
                </div>
            </div>
            <div class="col-md-3 d-none d-md-block text-end">
                <i class="bi bi-mortarboard text-primary opacity-25" style="font-size: 8rem;"></i>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (AuthStateService.CurrentUser?.GetRole() == "Admin")
        {
            <div class="col-md-4">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-people fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Student Directory</h5>
                        <p class="text-muted flex-grow-1">Manage student profiles, enrollments, and academic standings.</p>
                        <a href="/admin/students" class="btn btn-outline-primary btn-action">Open Students</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-book fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Course Catalog</h5>
                        <p class="text-muted flex-grow-1">Create and update course offerings and capacity limits.</p>
                        <a href="/admin/courses" class="btn btn-outline-success btn-action">Open Courses</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="bi bi-graph-up fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Analytics Report</h5>
                        <p class="text-muted flex-grow-1">View high-level performance data and weighted CGPAs.</p>
                        <a href="/admin/reports/grades" class="btn btn-outline-warning btn-action">View Reports</a>
                    </div>
                </div>
            </div>
        }
        else if (AuthStateService.CurrentUser?.GetRole() == "Faculty")
        {
            <div class="col-md-6">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-journal-check fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Grading Center</h5>
                        <p class="text-muted flex-grow-1">Enter scores and post grades for your course sections.</p>
                        <a href="/faculty/grades" class="btn btn-outline-primary btn-action">Start Grading</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-info bg-opacity-10 text-info">
                            <i class="bi bi-calendar-event fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Active Courses</h5>
                        <p class="text-muted flex-grow-1">Browse the university course offerings.</p>
                        <a href="/faculty/courses" class="btn btn-outline-info btn-action">View Courses</a>
                    </div>
                </div>
            </div>
        }
        else if (AuthStateService.CurrentUser?.GetRole() == "Student")
        {
            <div class="col-md-6">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-plus-square fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Enrollment</h5>
                        <p class="text-muted flex-grow-1">Register for upcoming courses for the current semester.</p>
                        <a href="/student/enroll" class="btn btn-outline-primary btn-action">Go to Enrollment</a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card stat-card h-100 border-0 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-award fs-2"></i>
                        </div>
                        <h5 class="fw-bold text-dark">My Transcript</h5>
                        <p class="text-muted flex-grow-1">View your posted grades and weighted CGPA progress.</p>
                        <a href="/student/grades" class="btn btn-outline-success btn-action">View Transcript</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

