@page "/admin/students"
@page "/admin/students/add"
@page "/admin/students/edit/{id:int}"
@using AcademicWebPortal.Models
@using AcademicWebPortal.Interfaces

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Student Management</h2>
        <button class="btn btn-success" @onclick="OpenAddModal">
            <i class="bi bi-person-plus"></i> Add New Student
        </button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" class="form-control border-start-0" 
                       placeholder="Search by name, email or ID..." 
                       @bind="SearchTerm" @bind:event="oninput" />
            </div>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle bg-white mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Semester</th>
                    <th>CGPA</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in FilteredStudents)
                {
                    <tr>
                        <td><strong>@student.StudentId</strong></td>
                        <td>@student.FullName</td>
                        <td>@student.Email</td>
                        <td>@student.CurrentSemester</td>
                        <td>
                            <span class="badge @(student.CGPA >= 3.5 ? "bg-success" : "bg-primary")">
                                @student.CGPA.ToString("F2")
                            </span>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-outline-info btn-sm me-1" @onclick="() => ViewDetails(student.Id)">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => OpenEditModal(student)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(student)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!FilteredStudents.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            No students found matching your search.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (ShowModal)
{
    <div class="modal fade show d-block modal-backdrop-custom" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(IsEditing ? "Edit Student" : "Add New Student")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <EditForm Model="CurrentStudent" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <InputText class="form-control" @bind-Value="CurrentStudent.FullName" />
                            <ValidationMessage For="() => CurrentStudent.FullName" class="text-danger" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" @bind-Value="CurrentStudent.Email" />
                            <ValidationMessage For="() => CurrentStudent.Email" class="text-danger" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Student ID</label>
                                <InputText class="form-control" @bind-Value="CurrentStudent.StudentId" />
                                <ValidationMessage For="() => CurrentStudent.StudentId" class="text-danger" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Semester</label>
                                <InputNumber class="form-control" @bind-Value="CurrentStudent.CurrentSemester" />
                                <ValidationMessage For="() => CurrentStudent.CurrentSemester" class="text-danger" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">CGPA</label>
                            <InputNumber class="form-control" @bind-Value="CurrentStudent.CGPA" step="0.01" />
                            <ValidationMessage For="() => CurrentStudent.CGPA" class="text-danger" />
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">@(IsEditing ? "Update Student" : "Save Student")</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteModal)
{
    <div class="modal fade show d-block modal-backdrop-custom" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowDeleteModal = false"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    @if (DeleteError != null)
                    {
                        <div class="alert alert-danger mb-3">@DeleteError</div>
                    }
                    <p class="lead">Are you sure you want to delete <strong>@StudentToDelete?.FullName</strong>?</p>
                    <p class="text-muted small">This action cannot be undone.</p>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="button" class="btn btn-light" @onclick="() => ShowDeleteModal = false">Cancel</button>
                    <button type="button" class="btn btn-danger px-4" @onclick="HandleDelete">Delete Student</button>
                </div>
            </div>
        </div>
    </div>
}
