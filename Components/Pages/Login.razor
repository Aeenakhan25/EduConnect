@page "/login"
@using AcademicWebPortal.Services
@using AcademicWebPortal.Models
@using AcademicWebPortal.Components.Layout
@layout EmptyLayout

<style>
    .login-container {
        background: linear-gradient(135deg, #f6f8fb 0%, #e9eff5 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .login-card {
        width: 100%;
        max-width: 400px;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05) !important;
        border: none;
        overflow: hidden;
    }
    .login-header {
        background: #0d6efd;
        padding: 2.5rem 1rem;
        color: white;
        text-align: center;
    }
    .form-control {
        padding: 12px 16px;
        border-radius: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
    }
    .btn-login {
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }
</style>

<div class="login-container">
    <div class="card login-card">
        <div class="login-header">
            <i class="bi bi-mortarboard-fill display-4 mb-2"></i>
            <h2 class="fw-bold">EduConnect</h2>
            <p class="mb-0 opacity-75">Secure Academic Portal Access</p>
        </div>
        <div class="card-body p-4 p-lg-5">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger border-0 rounded-3 small mb-4">@ErrorMessage</div>
            }
            <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Email Address</label>
                <input type="email" class="form-control" @bind="Email" placeholder="e.g. admin@edu.com" />
            </div>
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase">Password</label>
                <input type="password" class="form-control" @bind="Password" placeholder="••••••••" />
            </div>
            <button class="btn btn-primary btn-login w-100 shadow-sm" @onclick="HandleLogin" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Authenticating...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>
        </div>
        <div class="card-footer bg-light border-0 text-center py-3">
            <small class="text-muted">Enter any password for mock login.</small>
        </div>
    </div>
</div>